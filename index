<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
<title>FlipTrack</title>
<meta name="mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<meta name="apple-mobile-web-app-title" content="FlipTrack">
<meta name="application-name" content="FlipTrack">
<meta name="theme-color" content="#0a0a0f">
<link rel="apple-touch-icon" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 512 512'%3E%3Crect width='512' height='512' rx='110' fill='%230a0a0f'/%3E%3Crect x='56' y='56' width='400' height='400' rx='78' fill='%2313131a'/%3E%3Ctext x='256' y='310' font-family='Arial Black' font-size='230' font-weight='900' text-anchor='middle' fill='%2300e5a0'%3EF%3C/text%3E%3Ccircle cx='345' cy='158' r='58' fill='%237c6dff'/%3E%3Ctext x='345' y='178' font-family='Arial' font-size='54' font-weight='700' text-anchor='middle' fill='white'%3E%24%3C/text%3E%3C/svg%3E">
<link rel="manifest" href="data:application/manifest+json,%7B%22name%22%3A%22FlipTrack%22%2C%22short_name%22%3A%22FlipTrack%22%2C%22start_url%22%3A%22.%22%2C%22display%22%3A%22standalone%22%2C%22background_color%22%3A%22%230a0a0f%22%2C%22theme_color%22%3A%22%230a0a0f%22%7D">
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Mono:wght@300;400;500&display=swap" rel="stylesheet">
<style>
  :root{--bg:#0a0a0f;--surface:#13131a;--card:#1a1a25;--border:#2a2a3a;--accent:#00e5a0;--accent2:#7c6dff;--warn:#ff6b6b;--pending:#ffc14d;--text:#e8e8f0;--muted:#6b6b8a;--font:'Syne',sans-serif;--mono:'DM Mono',monospace}
  *{box-sizing:border-box;margin:0;padding:0}
  body{background:var(--bg);color:var(--text);font-family:var(--font);min-height:100dvh;padding-bottom:calc(40px + env(safe-area-inset-bottom))}
  #splash{position:fixed;inset:0;z-index:9999;background:var(--bg);display:flex;flex-direction:column;align-items:center;justify-content:center;gap:16px;transition:opacity 0.5s}
  #splash.hidden{opacity:0;pointer-events:none}
  .splash-icon{width:96px;height:96px;border-radius:22px;background:var(--surface);display:flex;align-items:center;justify-content:center;font-size:3rem;font-weight:900;color:var(--accent);border:1px solid var(--border);animation:pulse 1.8s ease-in-out infinite}
  @keyframes pulse{0%,100%{box-shadow:0 0 30px rgba(0,229,160,0.1)}50%{box-shadow:0 0 60px rgba(0,229,160,0.25)}}
  .splash-name{font-size:1.6rem;font-weight:800;letter-spacing:-1px}
  .splash-name span{color:var(--accent)}
  .splash-sub{font-family:var(--mono);font-size:0.7rem;color:var(--muted)}
  #installBanner{display:none;background:var(--card);border-bottom:1px solid var(--border);padding:10px 16px;align-items:center;justify-content:space-between;gap:10px}
  #installBanner.show{display:flex}
  .install-text{font-family:var(--mono);font-size:0.7rem;color:var(--text)}
  .install-text span{color:var(--accent);font-weight:500}
  .install-actions{display:flex;gap:8px;flex-shrink:0}
  .install-btn{background:var(--accent);color:#000;border:none;border-radius:6px;font-family:var(--font);font-weight:700;font-size:0.72rem;padding:6px 12px;cursor:pointer}
  .install-dismiss{background:none;border:1px solid var(--border);border-radius:6px;color:var(--muted);font-family:var(--mono);font-size:0.72rem;padding:6px 10px;cursor:pointer}
  header{background:var(--surface);border-bottom:1px solid var(--border);padding:16px 20px;padding-top:calc(16px + env(safe-area-inset-top));display:flex;align-items:center;justify-content:space-between;position:sticky;top:0;z-index:100}
  .logo{font-size:1.3rem;font-weight:800;letter-spacing:-0.5px}
  .logo span{color:var(--accent)}
  .header-date{font-family:var(--mono);font-size:0.72rem;color:var(--muted);text-align:right;line-height:1.5}
  .container{max-width:900px;margin:0 auto;padding:20px 16px}
  .stats-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:12px;margin-bottom:20px}
  @media(min-width:600px){.stats-grid{grid-template-columns:repeat(4,1fr)}}
  .stat-card{background:var(--card);border:1px solid var(--border);border-radius:12px;padding:14px;transition:border-color 0.2s}
  .stat-card:hover{border-color:var(--accent2)}
  .stat-label{font-family:var(--mono);font-size:0.62rem;color:var(--muted);text-transform:uppercase;letter-spacing:1px;margin-bottom:6px}
  .stat-value{font-size:1.5rem;font-weight:800;letter-spacing:-1px;line-height:1}
  .stat-value.green{color:var(--accent)}.stat-value.purple{color:var(--accent2)}.stat-value.red{color:var(--warn)}.stat-value.yellow{color:var(--pending)}
  .stat-sub{font-family:var(--mono);font-size:0.65rem;color:var(--muted);margin-top:4px}
  .profit-row{display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:20px}
  @media(max-width:500px){.profit-row{grid-template-columns:1fr}}
  .profit-card{background:var(--card);border:1px solid var(--border);border-radius:12px;padding:16px}
  .profit-card h3{font-size:0.7rem;font-family:var(--mono);color:var(--muted);text-transform:uppercase;letter-spacing:1px;margin-bottom:10px}
  .profit-big{font-size:2rem;font-weight:800;color:var(--accent);letter-spacing:-1.5px}
  .profit-detail{font-family:var(--mono);font-size:0.65rem;color:var(--muted);margin-top:6px;line-height:1.8}
  .section-title{font-size:0.7rem;font-family:var(--mono);color:var(--muted);text-transform:uppercase;letter-spacing:1.5px;margin-bottom:12px}
  .form-card{background:var(--card);border:1px solid var(--border);border-radius:12px;padding:16px;margin-bottom:20px}
  .upload-zone{border:2px dashed var(--border);border-radius:10px;padding:16px 12px;text-align:center;cursor:pointer;transition:border-color 0.2s,background 0.2s;margin-bottom:14px;position:relative}
  .upload-zone:hover,.upload-zone.drag-over{border-color:var(--accent2);background:rgba(124,109,255,0.05)}
  .upload-zone input[type=file]{position:absolute;inset:0;opacity:0;cursor:pointer;width:100%;height:100%;border:none;padding:0}
  .upload-icon{font-size:1.5rem;margin-bottom:5px}
  .upload-label{font-family:var(--mono);font-size:0.7rem;color:var(--muted);line-height:1.5}
  .upload-label strong{color:var(--accent2)}
  .ai-status{display:none;font-family:var(--mono);font-size:0.7rem;padding:8px 12px;border-radius:8px;margin-bottom:12px;align-items:center;gap:8px}
  .ai-status.loading{display:flex;background:rgba(124,109,255,0.1);color:var(--accent2);border:1px solid rgba(124,109,255,0.2)}
  .ai-status.success{display:flex;background:rgba(0,229,160,0.1);color:var(--accent);border:1px solid rgba(0,229,160,0.2)}
  .ai-status.error{display:flex;background:rgba(255,107,107,0.1);color:var(--warn);border:1px solid rgba(255,107,107,0.2)}
  .spinner{width:12px;height:12px;border:2px solid currentColor;border-top-color:transparent;border-radius:50%;animation:spin 0.7s linear infinite;flex-shrink:0}
  @keyframes spin{to{transform:rotate(360deg)}}
  .form-grid{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:10px}
  .form-grid.three{grid-template-columns:1fr 1fr 1fr}.form-grid.full{grid-template-columns:1fr}
  @media(max-width:500px){.form-grid.three{grid-template-columns:1fr 1fr}}
  label{display:block;font-family:var(--mono);font-size:0.62rem;color:var(--muted);text-transform:uppercase;letter-spacing:1px;margin-bottom:5px}
  input,select,textarea{width:100%;background:var(--surface);border:1px solid var(--border);border-radius:8px;color:var(--text);font-family:var(--mono);font-size:0.9rem;padding:10px 12px;outline:none;transition:border-color 0.2s;-webkit-appearance:none}
  input:focus,select:focus,textarea:focus{border-color:var(--accent)}
  input.ai-filled,textarea.ai-filled{border-color:var(--accent2)!important;background:rgba(124,109,255,0.07)}
  select option{background:var(--surface)}
  textarea{resize:vertical;min-height:60px}
  .btn{background:var(--accent);color:#000;border:none;border-radius:8px;font-family:var(--font);font-weight:700;font-size:0.9rem;padding:11px 20px;cursor:pointer;width:100%;transition:opacity 0.2s,transform 0.1s}
  .btn:hover{opacity:0.9}.btn:active{transform:scale(0.98)}
  .inv-card{background:var(--card);border:1px solid var(--border);border-radius:12px;overflow:hidden;margin-bottom:20px}
  .inv-header{display:flex;align-items:center;justify-content:space-between;padding:14px 16px;border-bottom:1px solid var(--border);flex-wrap:wrap;gap:8px}
  .inv-header h2{font-size:0.9rem;font-weight:700}
  .filter-tabs{display:flex;gap:6px;flex-wrap:wrap}
  .tab{font-family:var(--mono);font-size:0.65rem;padding:4px 10px;border-radius:20px;border:1px solid var(--border);cursor:pointer;background:transparent;color:var(--muted);transition:all 0.15s}
  .tab.active{background:var(--accent2);border-color:var(--accent2);color:#fff}
  .item-list{padding:8px}
  .item-row{display:grid;grid-template-columns:1fr auto auto auto;gap:10px;align-items:center;padding:12px 10px;border-radius:8px;transition:background 0.15s}
  .item-row:hover{background:var(--surface)}
  .item-name{font-weight:700;font-size:0.9rem;margin-bottom:3px}
  .item-meta{font-family:var(--mono);font-size:0.62rem;color:var(--muted)}
  .item-prices{text-align:right;font-family:var(--mono);font-size:0.78rem}
  .item-prices .buy{color:var(--warn)}.item-prices .sell{color:var(--accent);font-weight:500}
  @media(max-width:500px){.item-prices{display:none}}
  .status-select{font-family:var(--mono);font-size:0.6rem;padding:4px 8px;border-radius:20px;cursor:pointer;font-weight:500;letter-spacing:0.5px;outline:none;-webkit-appearance:none;appearance:none;text-align:center;border:1px solid transparent;background:transparent}
  .status-select.unlisted{background:rgba(107,107,138,0.15);color:var(--muted);border-color:rgba(107,107,138,0.3)}
  .status-select.listed{background:rgba(124,109,255,0.15);color:var(--accent2);border-color:rgba(124,109,255,0.3)}
  .status-select.pending{background:rgba(255,193,77,0.1);color:var(--pending);border-color:rgba(255,193,77,0.25)}
  .status-select.sold{background:rgba(0,229,160,0.1);color:var(--accent);border-color:rgba(0,229,160,0.25)}
  .status-select option{background:var(--surface);color:var(--text)}
  .del-btn{background:none;border:none;color:var(--muted);cursor:pointer;font-size:1rem;padding:4px;border-radius:4px;transition:color 0.15s;line-height:1}
  .del-btn:hover{color:var(--warn)}
  .edit-btn{background:none;border:none;color:var(--muted);cursor:pointer;font-size:0.85rem;padding:4px;border-radius:4px;transition:color 0.15s;line-height:1}
  .edit-btn:hover{color:var(--accent2)}
  .edit-panel{display:none;background:var(--surface);border-top:1px solid var(--border);padding:12px;gap:8px;flex-direction:column;border-radius:0 0 8px 8px}
  .edit-panel.open{display:flex}
  .edit-row{display:grid;grid-template-columns:1fr 1fr;gap:8px}
  .edit-row.three{grid-template-columns:1fr 1fr 1fr}.edit-row.full{grid-template-columns:1fr}
  .edit-label{font-family:var(--mono);font-size:0.58rem;color:var(--muted);text-transform:uppercase;letter-spacing:1px;margin-bottom:4px}
  .edit-input{width:100%;background:var(--card);border:1px solid var(--border);border-radius:6px;color:var(--text);font-family:var(--mono);font-size:0.82rem;padding:7px 10px;outline:none;transition:border-color 0.2s;-webkit-appearance:none}
  .edit-input:focus{border-color:var(--accent2)}
  .edit-input option{background:var(--card)}
  .edit-actions{display:flex;gap:8px}
  .btn-save{background:var(--accent2);color:#fff;border:none;border-radius:6px;font-family:var(--font);font-weight:700;font-size:0.8rem;padding:8px 16px;cursor:pointer;flex:1;transition:opacity 0.15s}
  .btn-save:hover{opacity:0.85}
  .btn-cancel{background:transparent;color:var(--muted);border:1px solid var(--border);border-radius:6px;font-family:var(--font);font-weight:600;font-size:0.8rem;padding:8px 14px;cursor:pointer}
  .item-wrap{border-radius:8px;overflow:hidden;border-bottom:1px solid var(--border)}
  .item-wrap:last-child{border-bottom:none}
  .empty-state{padding:40px;text-align:center;color:var(--muted);font-family:var(--mono);font-size:0.8rem}
  .platform-dot{display:inline-block;width:6px;height:6px;border-radius:50%;margin-right:4px;vertical-align:middle}
  .dot-ebay{background:#e53238}.dot-fb{background:#1877f2}.dot-both{background:var(--accent2)}.dot-other{background:var(--muted)}
</style>
</head>
<body>
<div id="splash"><div class="splash-icon">F</div><div class="splash-name">Flip<span>Track</span></div><div class="splash-sub">Reseller Dashboard</div></div>
<div id="installBanner"><div class="install-text">Add <span>FlipTrack</span> to your home screen</div><div class="install-actions"><button class="install-btn" onclick="installApp()">Install</button><button class="install-dismiss" onclick="dismissInstall()">✕</button></div></div>
<header><div class="logo">Flip<span>Track</span></div><div class="header-date" id="headerDate"></div></header>
<div class="container">
  <div class="stats-grid">
    <div class="stat-card"><div class="stat-label">Total Items</div><div class="stat-value purple" id="statTotal">0</div><div class="stat-sub">in inventory</div></div>
    <div class="stat-card"><div class="stat-label">Active Listings</div><div class="stat-value yellow" id="statListed">0</div><div class="stat-sub">listed / pending</div></div>
    <div class="stat-card"><div class="stat-label">Items Sold</div><div class="stat-value green" id="statSold">0</div><div class="stat-sub">all time</div></div>
    <div class="stat-card"><div class="stat-label">Capital Tied Up</div><div class="stat-value red" id="statCapital">$0</div><div class="stat-sub">unsold cost basis</div></div>
  </div>
  <div class="profit-row">
    <div class="profit-card"><h3>📅 Today's Profit</h3><div class="profit-big" id="profitToday">$0</div><div class="profit-detail" id="profitTodayDetail">No sales today yet</div></div>
    <div class="profit-card"><h3>📆 This Week's Profit</h3><div class="profit-big" id="profitWeek">$0</div><div class="profit-detail" id="profitWeekDetail">No sales this week yet</div></div>
  </div>
  <div class="section-title">+ Add New Item</div>
  <div class="form-card">
    <div class="upload-zone" id="uploadZone">
      <input type="file" id="screenshotInput" accept="image/*" onchange="handleScreenshot(event)">
      <div class="upload-icon">📸</div>
      <div class="upload-label"><strong>Drop a listing screenshot to auto-fill</strong><br>eBay or Facebook Marketplace · tap or drag & drop</div>
    </div>
    <div class="ai-status" id="aiStatus"><div class="spinner" id="aiSpinner"></div><span id="aiStatusText"></span></div>
    <div class="form-grid full"><div><label>Item Name</label><input type="text" id="fName" placeholder="e.g. Jordan 1 Retro High OG, Size 10" autocomplete="off"></div></div>
    <div class="form-grid"><div><label>Buy Price ($)</label><input type="number" id="fBuy" placeholder="0.00" step="0.01" min="0"></div><div><label>List / Sale Price ($)</label><input type="number" id="fSell" placeholder="0.00" step="0.01" min="0"></div></div>
    <div class="form-grid three">
      <div><label>Platform</label><select id="fPlatform"><option value="eBay">eBay</option><option value="FB Marketplace">FB Marketplace</option><option value="Both">Both</option><option value="Other">Other</option></select></div>
      <div><label>Status</label><select id="fStatus"><option value="unlisted">Unlisted</option><option value="listed">Listed</option><option value="pending">Pending</option><option value="sold">Sold</option></select></div>
      <div><label>Date Purchased</label><input type="date" id="fDate"></div>
    </div>
    <div class="form-grid full" style="margin-bottom:12px"><div><label>Notes / Condition</label><textarea id="fNotes" placeholder="e.g. Deadstock, minor box damage..."></textarea></div></div>
    <button class="btn" onclick="addItem()">ADD TO INVENTORY</button>
  </div>
  <div class="inv-card">
    <div class="inv-header"><h2>Inventory</h2><div class="filter-tabs"><button class="tab active" onclick="setFilter('all',this)">All</button><button class="tab" onclick="setFilter('unlisted',this)">Unlisted</button><button class="tab" onclick="setFilter('listed',this)">Listed</button><button class="tab" onclick="setFilter('pending',this)">Pending</button><button class="tab" onclick="setFilter('sold',this)">Sold</button></div></div>
    <div class="item-list" id="itemList"></div>
  </div>
</div>
<script>
const SK='fliptrack-inventory';let items=[],filter='all';
async function load(){try{const r=await window.storage.get(SK);return r?JSON.parse(r.value):[]}catch{return[]}}
async function save(a){try{await window.storage.set(SK,JSON.stringify(a))}catch(e){console.error(e)}}
async function init(){items=await load();document.getElementById('fDate').value=today();tick();render();const z=document.getElementById('uploadZone');z.addEventListener('dragover',e=>{e.preventDefault();z.classList.add('drag-over')});z.addEventListener('dragleave',()=>z.classList.remove('drag-over'));z.addEventListener('drop',e=>{e.preventDefault();z.classList.remove('drag-over');const f=e.dataTransfer.files[0];if(f&&f.type.startsWith('image/'))processImg(f)})}
function today(){return new Date().toISOString().split('T')[0]}
function tick(){const n=new Date();document.getElementById('headerDate').innerHTML=n.toLocaleDateString('en-US',{weekday:'long',month:'short',day:'numeric'})+'<br>'+n.toLocaleTimeString('en-US',{hour:'2-digit',minute:'2-digit'})}
function handleScreenshot(e){const f=e.target.files[0];if(f)processImg(f);e.target.value=''}
function aiSt(t,m){const el=document.getElementById('aiStatus'),tx=document.getElementById('aiStatusText'),sp=document.getElementById('aiSpinner');el.className='ai-status '+t;tx.textContent=m;sp.style.display=t==='loading'?'block':'none';if(t==='success'||t==='error')setTimeout(()=>el.className='ai-status',5000)}
async function processImg(file){aiSt('loading','Reading screenshot with AI…');const b64=await new Promise((r,j)=>{const x=new FileReader();x.onload=()=>r(x.result.split(',')[1]);x.onerror=j;x.readAsDataURL(file)});try{const res=await fetch('https://api.anthropic.com/v1/messages',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({model:'claude-sonnet-4-20250514',max_tokens:500,messages:[{role:'user',content:[{type:'image',source:{type:'base64',media_type:file.type||'image/jpeg',data:b64}},{type:'text',text:'Screenshot of eBay or FB Marketplace listing. Return ONLY valid JSON, no markdown:\n{"name":"item title","price":0.00,"platform":"eBay or FB Marketplace or Other","condition":"notes"}\nPrice = number only, null if unknown.'}]}]})});const d=await res.json();const raw=d.content.map(b=>b.text||'').join('').replace(/```json|```/g,'').trim();const p=JSON.parse(raw);if(p.name)fill('fName',p.name);if(p.price)fill('fSell',p.price);if(p.condition)fill('fNotes',p.condition);if(p.platform){const s=document.getElementById('fPlatform');const m=[...s.options].find(o=>o.value.toLowerCase().includes(p.platform.toLowerCase().replace('facebook marketplace','fb marketplace')));if(m){s.value=m.value;hi(s)}}document.getElementById('fStatus').value='listed';aiSt('success','✓ Filled from screenshot — add your buy price before saving')}catch(e){console.error(e);aiSt('error','✗ Could not read screenshot — fill in manually')}}
function fill(id,v){const el=document.getElementById(id);el.value=v;hi(el)}
function hi(el){el.classList.add('ai-filled');el.addEventListener('input',()=>el.classList.remove('ai-filled'),{once:true})}
async function addItem(){const name=document.getElementById('fName').value.trim();if(!name){alert('Enter an item name');return}const item={id:Date.now().toString(),name,buy:parseFloat(document.getElementById('fBuy').value)||0,sell:parseFloat(document.getElementById('fSell').value)||0,platform:document.getElementById('fPlatform').value,status:document.getElementById('fStatus').value,date:document.getElementById('fDate').value||today(),notes:document.getElementById('fNotes').value.trim(),soldDate:document.getElementById('fStatus').value==='sold'?today():null};items.unshift(item);await save(items);['fName','fBuy','fSell','fNotes'].forEach(id=>{const el=document.getElementById(id);el.value='';el.classList.remove('ai-filled')});document.getElementById('fDate').value=today();document.getElementById('fStatus').value='unlisted';render()}
async function changeStatus(id,ns){const item=items.find(i=>i.id===id);if(!item)return;const ws=item.status==='sold';item.status=ns;if(ns==='sold'&&!ws)item.soldDate=today();if(ns!=='sold')item.soldDate=null;await save(items);render()}
async function deleteItem(id){if(!confirm('Remove this item?'))return;items=items.filter(i=>i.id!==id);await save(items);render()}
async function saveEdit(id){const item=items.find(i=>i.id===id);if(!item)return;const n=document.getElementById('e-name-'+id).value.trim();if(!n){alert('Name required');return}const ws=item.status==='sold';item.name=n;item.buy=parseFloat(document.getElementById('e-buy-'+id).value)||0;item.sell=parseFloat(document.getElementById('e-sell-'+id).value)||0;item.platform=document.getElementById('e-plat-'+id).value;item.status=document.getElementById('e-status-'+id).value;item.date=document.getElementById('e-date-'+id).value;item.notes=document.getElementById('e-notes-'+id).value.trim();if(item.status==='sold'&&!ws)item.soldDate=today();if(item.status!=='sold')item.soldDate=null;await save(items);render()}
function toggleEdit(id){const p=document.getElementById('edit-'+id);if(!p)return;const o=p.classList.contains('open');document.querySelectorAll('.edit-panel.open').forEach(x=>x.classList.remove('open'));if(!o)p.classList.add('open')}
function setFilter(f,btn){filter=f;document.querySelectorAll('.tab').forEach(t=>t.classList.remove('active'));btn.classList.add('active');renderList()}
function ws(){const d=new Date();d.setDate(d.getDate()-d.getDay());return d.toISOString().split('T')[0]}
function prof(a){return a.reduce((s,i)=>s+(i.sell-i.buy),0)}
function render(){const sold=items.filter(i=>i.status==='sold'),active=items.filter(i=>i.status==='listed'||i.status==='pending'),cap=items.filter(i=>i.status!=='sold').reduce((s,i)=>s+i.buy,0);document.getElementById('statTotal').textContent=items.length;document.getElementById('statListed').textContent=active.length;document.getElementById('statSold').textContent=sold.length;document.getElementById('statCapital').textContent='$'+cap.toFixed(0);const t=today(),w=ws(),st=items.filter(i=>i.status==='sold'&&i.soldDate===t),sw=items.filter(i=>i.status==='sold'&&i.soldDate>=w),tp=prof(st),wp=prof(sw);document.getElementById('profitToday').textContent='$'+tp.toFixed(2);document.getElementById('profitWeek').textContent='$'+wp.toFixed(2);document.getElementById('profitTodayDetail').textContent=st.length?`${st.length} sale${st.length>1?'s':''} · avg $${(tp/st.length).toFixed(2)}`:'No sales today yet';document.getElementById('profitWeekDetail').textContent=sw.length?`${sw.length} sale${sw.length>1?'s':''} · avg $${(wp/sw.length).toFixed(2)}`:'No sales this week yet';renderList()}
function pdot(p){const c=p==='eBay'?'dot-ebay':p==='FB Marketplace'?'dot-fb':p==='Both'?'dot-both':'dot-other';return`<span class="platform-dot ${c}"></span>`}
function renderList(){const list=document.getElementById('itemList');const shown=filter==='all'?items:items.filter(i=>i.status===filter);if(!shown.length){list.innerHTML='<div class="empty-state">No items here yet.<br>Add your first item above ↑</div>';return}const ss=['unlisted','listed','pending','sold'],ps=['eBay','FB Marketplace','Both','Other'];list.innerHTML=shown.map(item=>{const pr=item.sell-item.buy,roi=item.buy>0?((pr/item.buy)*100).toFixed(0):'—',so=ss.map(s=>`<option value="${s}" ${item.status===s?'selected':''}>${s}</option>`).join(''),po=ps.map(p=>`<option value="${p}" ${item.platform===p?'selected':''}>${p}</option>`).join('');return`<div class="item-wrap"><div class="item-row"><div><div class="item-name">${esc(item.name)}</div><div class="item-meta">${pdot(item.platform)}${item.platform} &nbsp;·&nbsp; ${item.date}${item.notes?` &nbsp;·&nbsp; ${esc(item.notes).substring(0,40)}${item.notes.length>40?'…':''}`:''}</div></div><div class="item-prices"><div class="buy">↓ $${item.buy.toFixed(2)}</div><div class="sell">↑ $${item.sell.toFixed(2)}</div><div style="color:${pr>=0?'var(--accent)':'var(--warn)'};font-size:0.6rem;margin-top:2px">${pr>=0?'+':''}$${pr.toFixed(2)} (${roi}%)</div></div><select class="status-select ${item.status}" onchange="changeStatus('${item.id}',this.value);this.className='status-select '+this.value;">${so}</select><div style="display:flex;gap:2px;align-items:center"><button class="edit-btn" onclick="toggleEdit('${item.id}')">✏️</button><button class="del-btn" onclick="deleteItem('${item.id}')">✕</button></div></div><div class="edit-panel" id="edit-${item.id}"><div class="edit-row full"><div><div class="edit-label">Item Name</div><input class="edit-input" id="e-name-${item.id}" type="text" value="${esc(item.name)}"></div></div><div class="edit-row"><div><div class="edit-label">Buy Price ($)</div><input class="edit-input" id="e-buy-${item.id}" type="number" step="0.01" min="0" value="${item.buy}"></div><div><div class="edit-label">Sale Price ($)</div><input class="edit-input" id="e-sell-${item.id}" type="number" step="0.01" min="0" value="${item.sell}"></div></div><div class="edit-row three"><div><div class="edit-label">Platform</div><select class="edit-input" id="e-plat-${item.id}">${po}</select></div><div><div class="edit-label">Status</div><select class="edit-input" id="e-status-${item.id}">${so}</select></div><div><div class="edit-label">Date</div><input class="edit-input" id="e-date-${item.id}" type="date" value="${item.date}"></div></div><div class="edit-row full"><div><div class="edit-label">Notes</div><input class="edit-input" id="e-notes-${item.id}" type="text" value="${esc(item.notes||'')}"></div></div><div class="edit-actions"><button class="btn-save" onclick="saveEdit('${item.id}')">Save Changes</button><button class="btn-cancel" onclick="toggleEdit('${item.id}')">Cancel</button></div></div></div>`}).join('')}
function esc(s){return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;')}
init();setInterval(tick,60000);
window.addEventListener('load',()=>{setTimeout(()=>{const s=document.getElementById('splash');s.classList.add('hidden');setTimeout(()=>s.remove(),500)},1200)});
let dip=null;
window.addEventListener('beforeinstallprompt',e=>{e.preventDefault();dip=e;document.getElementById('installBanner').classList.add('show')});
function installApp(){if(!dip)return;dip.prompt();dip.userChoice.then(()=>{dip=null;dismissInstall()})}
function dismissInstall(){document.getElementById('installBanner').classList.remove('show')}
window.addEventListener('appinstalled',()=>{dismissInstall();dip=null});
</script>
</body>
</html>
